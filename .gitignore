# Build outputs
bin/
*.exe

# Environment and secrets — never commit real values
# Track only .env.example; all other .env* files (including .env) stay local.
.env
.env.*
!.env.example
*.pem
credentials.json
**/uploads/

# Cursor workspace (local agent context, memory, rules)
.cursor/

# Dependencies
node_modules/

# Local tool checkouts (see tools/repos/README.md)
/tools/repos/*/
!/tools/repos/README.md
/tools/bin/*
!/tools/bin/.gitkeep

# Kùzu bridge venv + embedded DB files
/services/*/.venv/
**/__pycache__/
*.egg-info/
/data/
/services/kuzu-bridge/data/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
