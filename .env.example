# QuarkGate — environment template (BYOK model)
# Copy to .env and fill locally — never commit .env
#
# Memory providers: mirror quarkOS/.env (see ../../.env.example)
# WP11 spec: docs/plans/project_quark_phase_11_5e1f43aa.plan.md

QUARKGATE_CREDENTIAL_MODE=byok

# =============================================================================
# WP11 MEMORY PROVIDERS (sync with quarkOS/.env)
# =============================================================================

SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_TABLE=documents

QUARKOS_REDIS_URL=redis://localhost:6379

VAULT_PATH=./vault
MEMORY_CURATOR_URL=http://127.0.0.1:8082
MEMORY_MATRIX_PATH=config/memory_matrix.yaml.example
MEMORY_SPECTRUM_CONFIG_PATH=config/memory_spectrum.yaml.example

EMBED_PROVIDER=stub
EMBED_WORKER_URL=http://127.0.0.1:8087

PROMOTION_ENABLED=false

LETTA_ENABLED=false
LETTA_BRIDGE_URL=http://127.0.0.1:8089
LETTA_API_KEY=
LETTA_BASE_URL=http://localhost:8283
LETTA_AGENT_ID=

HINDSIGHT_ENABLED=true
HINDSIGHT_API_KEY=
HINDSIGHT_GIT_REPO_PATH=.
HINDSIGHT_DATA_PATH=data/agents.mmd/tier2
AGENTS_MMD_DATA=data/agents.mmd

ZEP_MODE=disabled
ZEP_API_KEY=
ZEP_API_BASE=https://api.getzep.com
ZEP_INGEST_WORKER_URL=http://127.0.0.1:8091
GRAPHITI_BASE_URL=http://127.0.0.1:8092

KUZU_ENABLED=false
KUZU_DB_PATH=data/kuzu/memory_graph.kuzu
KUZU_BRIDGE_URL=http://127.0.0.1:8093
KUZU_REPO_PATH=tools/repos/kuzu

LANCE_ENABLED=false
LANCEDB_URI=data/lancedb
LANCEDB_API_KEY=
LANCEDB_REGION=us-east-1
CLIP_ENABLED=false
CLIP_MODEL_ID=openai/clip-vit-base-patch32
BROWSER_ACTORS_ENABLED=false

# L4 — LangGraph skills + LangSmith
LANGGRAPH_SKILLS_ENABLED=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=quarkgate
LANGSMITH_PROJECT_ID=
LANGSMITH_ENDPOINT=https://apac.api.smith.langchain.com
LANGSMITH_HUB_URL=https://apac.smith.langchain.com
LANGSMITH_TRACING=false
LANGSMITH_WORKSPACE_ID=
LANGSMITH_SKILLS_DATASET=quarkgate

# HITL — Anytype (recovery phrase + API credentials — never commit)
ANYTYPE_ENABLED=false
ANYTYPE_BOT_NAME=quark-bot
ANYTYPE_ACCOUNT_ID=
ANYTYPE_ACCOUNT_KEY=
ANYTYPE_RPC_URL=http://127.0.0.1:31007
ANYTYPE_API_URL=http://127.0.0.1:31012
ANYTYPE_RECOVERY_PHRASE=
ANYTYPE_API_KEY=

SLEEP_CYCLE_ENABLED=false
MEMORY_SLEEP_WORKER_URL=http://127.0.0.1:8088

# LLM — all model calls via OpenRouter (BYOK)
OPENROUTER_API_KEY=

# =============================================================================
# WP10 — EXECUTION (e2b) + DIGITALOCEAN (control-plane VPS)
# =============================================================================

EXECUTOR_BACKEND=e2b
EXECUTOR_MODE=controller
DOCKER_ENABLED=false
E2B_API_KEY=
E2B_API_KEY=
E2B_API_BASE=https://api.e2b.dev
E2B_TEMPLATE_ID=base

DIGITALOCEAN_TOKEN=
DO_REGION=syd1
DO_PROJECT_NAME=quarkgate
DO_PROJECT_ID=
DO_ACCOUNT_UUID=
DO_DROPLET_NAME=quarkgate
DO_DROPLET_SIZE=s-2vcpu-4gb

# =============================================================================
# QUARKGATE CLIENT + DRIVER BYOK
# =============================================================================

QUARKGATE_KEY=
QUARKGATE_ENABLED=true
QUARKGATE_LEDGER_WORKER=true
QUARKGATE_URL=http://127.0.0.1:8080

# Dev unified gateway (make dev-up) — dashboard + supervisor + /qg proxy in one process
DEV_GATEWAY_PORT=8090
DEV_GATEWAY_URL=http://127.0.0.1:8090
DEV_DASHBOARD_URL=http://127.0.0.1:8090
# Optional: route QuarkGate client through unified proxy instead of :8080 direct
# QUARKGATE_URL=http://127.0.0.1:8090/qg

# MVQ task-service moved to :8081 so Hermes + QuarkGate can run together
TASK_SERVICE_PORT=8081
TASK_API_URL=http://127.0.0.1:8081
HERMES_URL=http://127.0.0.1:8084
E2E_STRICT=1

APIFY_TOKEN=
APIFY_ACTOR_ID=apify/hello-world

# =============================================================================
# QUARKGATE RUNTIME (ledger — no Docker: host Redis :6379 + Supabase Postgres)
# Run: python3 scripts/resolve-dev-infra.py  (sets REDIS_URL + DATABASE_URL automatically)

LISTEN_ADDR=:8080
# Overridden by resolve-dev-infra.py when Docker is off:
REDIS_URL=redis://127.0.0.1:6379/0
DATABASE_URL=
SUPABASE_PASSWORD=
VAULT_KEK=dev-only-32-byte-key-change-me!!
RECONCILE_AUTO_FIX=true

QUARKGATE_DEV_EMAIL=dev@quarkgate.dev
QUARKGATE_DEPOSIT_CREDITS=1000
QUARKGATE_KEY_LABEL=dev-key
