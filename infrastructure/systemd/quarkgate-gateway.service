[Unit]
Description=QuarkGate API gateway
After=network-online.target docker.service
Wants=network-online.target
Requires=docker.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/quarkOS/quarkgate
EnvironmentFile=/opt/quarkOS/quarkgate/.env
ExecStart=/opt/quarkOS/quarkgate/bin/gateway
Restart=on-failure
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
